// Run: npx prisma db pull  →  auto-generates this from your db_food
// Then: npx prisma generate  →  generates PrismaClient
// This is a manual reference matching your assignment.sql

generator client {
  provider     = "prisma-client-js"
  output       = "../src/common/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  user_id   Int        @id @default(autoincrement())
  full_name String?    @db.VarChar(255)
  email     String     @unique @db.VarChar(255)
  password  String     @db.VarChar(255)
  orders    order[]
  likes     like_res[]
  ratings   rate_res[]
}

model restaurant {
  res_id   Int        @id @default(autoincrement())
  res_name String?    @db.VarChar(255)
  image    String?    @db.VarChar(255)
  desc     String?    @default("Null") @db.VarChar(255)
  likes    like_res[]
  ratings  rate_res[]
}

model food_type {
  type_id   Int    @id @default(autoincrement())
  type_name String @db.VarChar(30)
  foods     food[]
}

model food {
  food_id   Int        @id @default(autoincrement())
  food_name String?    @db.VarChar(30)
  image     String?    @db.VarChar(255)
  price     Float?
  desc      String?    @default("Null") @db.VarChar(255)
  type_id   Int?
  food_type food_type? @relation(fields: [type_id], references: [type_id])
  sub_foods sub_food[]
  orders    order[]
}

model sub_food {
  sub_id    Int         @id @default(autoincrement())
  sub_name  String?     @db.VarChar(30)
  sub_price Float?
  food_id   Int?
  food      food?       @relation(fields: [food_id], references: [food_id])
  order_sub order_sub[]
}

model order {
  order_id  Int         @id @default(autoincrement())
  user_id   Int?
  food_id   Int?
  amount    Int?
  code      String      @unique @db.VarChar(255)
  user      user?       @relation(fields: [user_id], references: [user_id])
  food      food?       @relation(fields: [food_id], references: [food_id])
  order_sub order_sub[]
}

model order_sub {
  order_id Int
  sub_id   Int
  order    order    @relation(fields: [order_id], references: [order_id])
  sub_food sub_food @relation(fields: [sub_id], references: [sub_id])

  @@id([order_id, sub_id])
}

model like_res {
  user_id    Int
  res_id     Int
  date_like  DateTime   @default(now())
  user       user       @relation(fields: [user_id], references: [user_id])
  restaurant restaurant @relation(fields: [res_id], references: [res_id])

  @@id([user_id, res_id])
}

model rate_res {
  user_id    Int
  res_id     Int
  amount     Int
  date_rate  DateTime   @default(now())
  user       user       @relation(fields: [user_id], references: [user_id])
  restaurant restaurant @relation(fields: [res_id], references: [res_id])

  @@id([user_id, res_id])
}
